generator client {
  provider = "prisma-client"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
}

enum DokkanType {
  STR
  AGL
  TEQ
  INT
  PHY
}

enum DokkanRarity {
  SSR
  UR
  LR
}

enum DokkanClass {
  SUPER
  EXTREME
}

model Character {
  id                    String                 @id @default(cuid())
  name                  String
  type                  DokkanType
  rarity                DokkanRarity
  class                 DokkanClass
  baseAtk               Int
  baseDef               Int
  kiMultiplier          Float
  superAttackMultiplier Float
  /// リーダースキルのATK倍率(任意)。パーティ編成でのリーダースキル合成プレビューに使用
  leaderSkillMultiplier Float?
  /// Dragon Ball Z Dokkan Battle Wiki (Fandom) 上の該当キャラページURL。CC BY-SA 3.0の出典表示に使用
  sourceUrl             String?
  /// Wikiインポート元の外部ID(DokkanAPIのカードID)。再インポート時の重複防止用
  externalId            String?                @unique
  createdAt             DateTime               @default(now())
  linkSkills            CharacterLinkSkill[]
  supportItems          CharacterSupportItem[]
  /// このキャラがよく組むパーティーメンバーとして登録した他キャラ
  partyMembers          CharacterPartyMember[] @relation("PartyOwner")
  /// このキャラを他キャラのパーティーメンバーとして登録している側からの参照
  partyMemberOf         CharacterPartyMember[] @relation("PartyMemberRef")
  partyMemberships      PartyMember[]
}

/// 保存済みパーティ編成(6スロット)。被ダメ計算でメンバー全員分を一括計算するために使用
model Party {
  id        String        @id @default(cuid())
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  members   PartyMember[]
}

model PartyMember {
  id          String    @id @default(cuid())
  partyId     String
  characterId String
  /// 0=リーダー, 1-4=サブ, 5=フレンド枠。隣接スロット同士でリンクスキルが発動する判定に使用
  slotIndex   Int
  party       Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([partyId, slotIndex])
}

/// リンクスキルの共通マスタ。同じリンク名を持つキャラ同士が隣接すると発動する(Dokkan本来の仕様)
model LinkSkill {
  id          String               @id @default(cuid())
  name        String               @unique
  /// 効果メモ (例: ATK & DEF +3%, 気力+2)
  description String?
  createdAt   DateTime             @default(now())
  characters  CharacterLinkSkill[]
}

model CharacterLinkSkill {
  id          String    @id @default(cuid())
  characterId String
  linkSkillId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  linkSkill   LinkSkill @relation(fields: [linkSkillId], references: [id], onDelete: Cascade)

  @@unique([characterId, linkSkillId])
}

/// サポートアイテム(サポートメモリー)の共通マスタ
model SupportItem {
  id         String                 @id @default(cuid())
  name       String
  /// 効果メモ (例: ATK+5000 DEF+3000)
  effect     String
  createdAt  DateTime               @default(now())
  characters CharacterSupportItem[]
}

model CharacterSupportItem {
  id            String      @id @default(cuid())
  characterId   String
  supportItemId String
  character     Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  supportItem   SupportItem @relation(fields: [supportItemId], references: [id], onDelete: Cascade)

  @@unique([characterId, supportItemId])
}

/// 「このキャラとよく組むパーティーメンバー」の登録(参照用。リンク共有判定への自動計算はまだ未実装)
model CharacterPartyMember {
  id          String    @id @default(cuid())
  characterId String
  memberId    String
  character   Character @relation("PartyOwner", fields: [characterId], references: [id], onDelete: Cascade)
  member      Character @relation("PartyMemberRef", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([characterId, memberId])
}

model Enemy {
  id                     String   @id @default(cuid())
  name                   String
  type                   DokkanType
  atk                    Int
  def                    Int
  superAttackMultiplier  Float
  /// 敵自身のガード・被ダメージ軽減率(%)。プレイヤー側の攻撃に対する軽減
  damageReductionPercent Float    @default(0)
  sourceUrl              String?
  createdAt              DateTime @default(now())
}

/// クエスト/イベントのステージ攻略メモ。敵の被ダメージ計算(1キャラ分)にも使用
model Stage {
  id         String          @id @default(cuid())
  /// フル表示名 (例: レッドゾーン ブロリー)
  name       String
  /// イベント名 (例: レッドゾーン)
  event      String
  /// 難易度・ステージ番号 (例: STAGE8)
  difficulty String
  /// 登録済み敵数のキャッシュ(enemiesの件数)
  enemyCount Int             @default(0)
  sourceUrl  String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  enemies    StageEnemy[]
  mechanics  StageMechanic[]
}

/// ステージ専用の敵データ(汎用Enemyとは別。ステージ間で使い回さない)
model StageEnemy {
  id                    String     @id @default(cuid())
  name                  String
  hp                    BigInt
  atk                   Int
  def                   Int
  type                  DokkanType
  /// この敵の必殺技倍率。被ダメージ計算(敵からの攻撃)に使用
  superAttackMultiplier Float      @default(1)
  /// 敵のガード・被ダメージ軽減率(%)
  guardReduction        Float      @default(0)
  /// 複数体ウェーブの表示順(登録順に自動採番)
  waveOrder             Int        @default(0)
  stageId               String
  stage                 Stage      @relation(fields: [stageId], references: [id], onDelete: Cascade)
}

/// ステージ固有のギミック・特殊ルールのメモ(計算には使わない参照用)
model StageMechanic {
  id       String @id @default(cuid())
  mechanic String
  stageId  String
  stage    Stage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
}

enum DokkanType {
  STR
  AGL
  TEQ
  INT
  PHY
}

enum DokkanRarity {
  SSR
  UR
  LR
}

enum DokkanClass {
  SUPER
  EXTREME
}

model Character {
  id                    String       @id @default(cuid())
  name                  String
  type                  DokkanType
  rarity                DokkanRarity
  class                 DokkanClass
  baseAtk               Int
  baseDef               Int
  kiMultiplier          Float
  superAttackMultiplier Float
  /// Dragon Ball Z Dokkan Battle Wiki (Fandom) 上の該当キャラページURL。CC BY-SA 3.0の出典表示に使用
  sourceUrl             String?
  /// Wikiインポート元の外部ID(DokkanAPIのカードID)。再インポート時の重複防止用
  externalId            String?      @unique
  createdAt             DateTime     @default(now())
}

model Enemy {
  id                     String   @id @default(cuid())
  name                   String
  type                   DokkanType
  atk                    Int
  def                    Int
  superAttackMultiplier  Float
  /// 敵自身のガード・被ダメージ軽減率(%)。プレイヤー側の攻撃に対する軽減
  damageReductionPercent Float    @default(0)
  sourceUrl              String?
  createdAt              DateTime @default(now())
}

/// クエスト/イベントのステージ攻略メモ。敵の被ダメージ計算(1キャラ分)にも使用
model Stage {
  id         String          @id @default(cuid())
  /// フル表示名 (例: レッドゾーン ブロリー)
  name       String
  /// イベント名 (例: レッドゾーン)
  event      String
  /// 難易度・ステージ番号 (例: STAGE8)
  difficulty String
  /// 登録済み敵数のキャッシュ(enemiesの件数)
  enemyCount Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  enemies    StageEnemy[]
  mechanics  StageMechanic[]
}

/// ステージ専用の敵データ(汎用Enemyとは別。ステージ間で使い回さない)
model StageEnemy {
  id                    String     @id @default(cuid())
  name                  String
  hp                    BigInt
  atk                   Int
  def                   Int
  type                  DokkanType
  /// この敵の必殺技倍率。被ダメージ計算(敵からの攻撃)に使用
  superAttackMultiplier Float      @default(1)
  stageId               String
  stage                 Stage      @relation(fields: [stageId], references: [id], onDelete: Cascade)
}

/// ステージ固有のギミック・特殊ルールのメモ(計算には使わない参照用)
model StageMechanic {
  id       String @id @default(cuid())
  mechanic String
  stageId  String
  stage    Stage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
}

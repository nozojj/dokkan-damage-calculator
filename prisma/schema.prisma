generator client {
  provider = "prisma-client"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
}

enum DokkanType {
  STR
  AGL
  TEQ
  INT
  PHY
}

enum DokkanRarity {
  SSR
  UR
  LR
}

enum DokkanClass {
  SUPER
  EXTREME
}

model Character {
  id                    String       @id @default(cuid())
  name                  String
  type                  DokkanType
  rarity                DokkanRarity
  class                 DokkanClass
  baseAtk               Int
  baseDef               Int
  kiMultiplier          Float
  superAttackMultiplier Float
  /// Dragon Ball Z Dokkan Battle Wiki (Fandom) 上の該当キャラページURL。CC BY-SA 3.0の出典表示に使用
  sourceUrl             String?
  /// Wikiインポート元の外部ID(DokkanAPIのカードID)。再インポート時の重複防止用
  externalId            String?      @unique
  createdAt             DateTime     @default(now())
}

model Enemy {
  id                     String       @id @default(cuid())
  name                   String
  type                   DokkanType
  atk                    Int
  def                    Int
  superAttackMultiplier  Float
  /// 敵自身のガード・被ダメージ軽減率(%)。プレイヤー側の攻撃に対する軽減
  damageReductionPercent Float        @default(0)
  sourceUrl              String?
  createdAt              DateTime     @default(now())
  stages                 StageEnemy[]
}

model Stage {
  id        String       @id @default(cuid())
  name      String
  createdAt DateTime     @default(now())
  enemies   StageEnemy[]
}

model StageEnemy {
  id      String @id @default(cuid())
  order   Int    @default(0)
  stageId String
  enemyId String
  stage   Stage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  enemy   Enemy  @relation(fields: [enemyId], references: [id], onDelete: Cascade)

  @@unique([stageId, enemyId])
}
